/*
  console.rc - Help and version resources for CONSOLE.DLL.

  Jason Hood, 20 October, 2009.

  Originally I had one big help screen, but the dialog is limited to 4095
  characters, so now it's split into several.
*/

#include <windows.h>
#include "resources.h"

STRINGTABLE
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
{
  0, "Console Commands"
  1, "Game Commands"
  2, "Base Commands"
  3, "Movement Commands"
  4, "Ship Commands"
  5, "HUD Commands"
  6, "Player Commands"

IDS_VERSION,		"Version 1.24 (7 May, 2016)."
IDS_GAME_SAVED+0,	"Game NOT saved."
IDS_GAME_SAVED+1,	"Game saved."
