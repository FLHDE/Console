IDS_SOLD_FOR,		"Sold %s for %s."
IDS_SPECIFY_BASE,	"Specify base."
IDS_GHOST_OFF,		"Ghost: off"
IDS_GHOST_ON,		"Ghost: on"
IDS_GODMODE_OFF,	"Godmode: off"
IDS_GODMODE_ON, 	"Godmode: on"
IDS_NTB_OFF,		"NTB: off"
IDS_NTB_ON+0,		"NTB: on"
IDS_NTB_ON+1,		"NTB: sight"
IDS_SHOW_ON,		"Show: on"
IDS_SHOW_OFF,		"Show: off"
IDS_HOUSES_OFF, 	"House labels: off"
IDS_HOUSES_ON,		"House labels: on"
IDS_PPATHS_UNFILTERED,	"Patrol Paths: unfiltered"
IDS_PPATHS_FILTERED,	"Patrol Paths: filtered"
IDS_ZOOM_TIME,		"Zoom time = %g"
IDS_FACTION_NOT_FOUND,	"Faction not found."
IDS_REP,		"Reputation: %g"
IDS_REP_SAVED,		"Rep saved."
IDS_REP_LOADED, 	"Rep loaded."
IDS_MONKEY,		"Monkey."
IDS_ROBOT,		"Robot."
